## 🔟 Overriding Admin Methods — Advanced Control

```python
@admin.register(Post)
class PostAdmin(admin.ModelAdmin):

    # Custom logic when admin saves an object
    def save_model(self, request, obj, form, change):
        if not obj.pk:                   # if it's a new object
            obj.author = request.user    # set author to current admin user
        super().save_model(request, obj, form, change)

    # Custom logic before an object is deleted
    def delete_model(self, request, obj):
        print(f"Admin {request.user} deleted post: {obj.title}")
        super().delete_model(request, obj)

    # Limit which objects this admin user can see
    def get_queryset(self, request):
        qs = super().get_queryset(request)
        if request.user.is_superuser:
            return qs
        return qs.filter(author=request.user)  # non-superusers see only their own

    # Control which fields are shown based on user role
    def get_fields(self, request, obj=None):
        fields = super().get_fields(request, obj)
        if not request.user.is_superuser:
            fields = [f for f in fields if f != 'is_featured']
        return fields
```

